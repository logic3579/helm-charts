                "targets": [
                    {
                        "expr": "pilot_conflict_inbound_listener{job=\"istiod\", env=\"$env\"} + pilot_conflict_outbound_listener_tcp_over_current_tcp{job=\"istiod\", env=\"$env\"} or vector(0)",
