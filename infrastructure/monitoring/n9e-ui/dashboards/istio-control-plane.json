                    "standardOptions": {
                        "util": "seconds",
                        "decimals": 3,
                        "min": 0
                    },
                    "thresholds": {},
                    "tooltip": {
                        "mode": "all",
                        "sort": "desc"
                    }
                },
                "targets": [
                    {
                        "expr": "histogram_quantile(0.50, sum(rate(pilot_proxy_convergence_time_bucket{job=\"istiod\", env=\"$env\"}[5m])) by (le))",
